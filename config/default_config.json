{
  "api": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "base_url": null,
    "max_tokens": 8192
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TaskCreate",
      "TaskList",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo rm *)"
    ],
    "ask": [
      "Write",
      "Edit",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(npm *)",
      "Bash(pip *)",
      "Bash(python *)",
      "Bash(git push *)",
      "Bash(git commit *)"
    ]
  },
  "ui": {
    "theme": "dark",
    "output_style": "explanatory",
    "vim_mode": false
  },
  "context": {
    "include": ["src/", "lib/", "app/"],
    "exclude": ["node_modules/", "__pycache__/", ".git/", "dist/"]
  }
}